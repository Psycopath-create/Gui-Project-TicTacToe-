#include <SFML/Graphics.hpp>
#include <iostream>
 
// ── Shared game state ─────────────────────────────────────────────────────────
extern char board[3][3];   // defined in your main game file
 
const int WINDOW_SIZE = 600;
const int CELL_SIZE   = WINDOW_SIZE / 3;   // 200 px per cell
 
char currentPlayer = 'X';
bool gameOver      = false;
 
// ── Forward declarations (already defined elsewhere in your project) ──────────
char checkWinner();
bool isBoardFull();
 
// ─────────────────────────────────────────────────────────────────────────────
//  resetBoard()
//  Call this at game start and whenever the player presses R.
// ─────────────────────────────────────────────────────────────────────────────
void resetBoard()
{
    for (int r = 0; r < 3; ++r)
        for (int c = 0; c < 3; ++c)
            board[r][c] = ' ';
 
    currentPlayer = 'X';
    gameOver      = false;
 
    std::cout << "\n=== Board reset. X goes first. ===\n";
}
 
// ─────────────────────────────────────────────────────────────────────────────
//  handleClick(px, py)
//  Call this inside your sf::Event::MouseButtonPressed block.
// ─────────────────────────────────────────────────────────────────────────────
void handleClick(int px, int py)
{
    // 1. Ignore all input once the game is over
    if (gameOver) return;
 
    // 2. Convert pixel position → grid cell (both become 0, 1, or 2)
    int col = px / CELL_SIZE;
    int row = py / CELL_SIZE;
 
    // 3. Clamp — pixel should always be in range, but be defensive
    if (row < 0 || row > 2 || col < 0 || col > 2) return;
 
    // 4. Prevent overwriting an already-filled cell
    if (board[row][col] != ' ')
    {
        std::cout << "Cell (" << row << "," << col << ") is already taken!\n";
        return;
    }
 
    // 5. Place the current player's mark
    board[row][col] = currentPlayer;
    std::cout << currentPlayer << " played at row=" << row << ", col=" << col << "\n";
 
    // 6. Check for a winner
    char winner = checkWinner();
    if (winner != ' ')
    {
        std::cout << "*** Player " << winner << " wins! Press R to restart. ***\n";
        gameOver = true;
        return;
    }
 
    // 7. Check for a draw
    if (isBoardFull())
    {
        std::cout << "*** It's a draw! Press R to restart. ***\n";
        gameOver = true;
        return;
    }
 
    // 8. Alternate turns
    currentPlayer = (currentPlayer == 'X') ? 'O' : 'X';
}
 
// ─────────────────────────────────────────────────────────────────────────────
//  processEvents(window)
//  Paste this call inside your main loop, or merge it with your existing
//  event loop. It only handles input — rendering is untouched.
// ─────────────────────────────────────────────────────────────────────────────
void processEvents(sf::RenderWindow& window)
{
    sf::Event event;
    while (window.pollEvent(event))
    {
        // Window close
        if (event.type == sf::Event::Closed)
            window.close();
 
        // R key → reset the board
        if (event.type == sf::Event::KeyPressed &&
            event.key.code == sf::Keyboard::R)
        {
            resetBoard();
        }
 
        // Left mouse click → try to place a mark
        if (event.type == sf::Event::MouseButtonPressed &&
            event.mouseButton.button == sf::Mouse::Left)
        {
            handleClick(event.mouseButton.x, event.mouseButton.y);
        }
    }
}
