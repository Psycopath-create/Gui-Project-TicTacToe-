#include <SFML/Graphics.hpp>
#include "starter.h"

void drawGrid(sf::RenderWindow& window) {
    // 1. Draw the Grid Lines
    sf::RectangleShape line(sf::Vector2f(600.f, 5.f));
    line.setFillColor(sf::Color::White);

    // Horizontal lines
    line.setPosition(0, 200.f);
    window.draw(line);
    line.setPosition(0, 400.f);
    window.draw(line);

    // Vertical lines
    line.setSize(sf::Vector2f(5.f, 600.f));
    line.setPosition(200.f, 0);
    window.draw(line);
    line.setPosition(400.f, 0);
    window.draw(line);

    // 2. Loop through the board and draw symbols
    for (int i = 0; i < 3; ++i) {
        for (int j = 0; j < 3; ++j) {
            float xOffset = j * 200.f;
            float yOffset = i * 200.f;

            if (board[i][j] == 'O') {
                // Draw Green Circle
                sf::CircleShape circle(70.f);
                circle.setFillColor(sf::Color::Transparent);
                circle.setOutlineThickness(10.f);
                circle.setOutlineColor(sf::Color::Green);
                circle.setPosition(xOffset + 30.f, yOffset + 30.f);
                window.draw(circle);
            } 
            else if (board[i][j] == 'X') {
                // Draw Red 'X' (two lines)
                sf::RectangleShape cross1(sf::Vector2f(200.f, 10.f));
                cross1.setFillColor(sf::Color::Red);
                cross1.setPosition(xOffset + 20.f, yOffset + 20.f);
                cross1.setRotation(45.f);
                window.draw(cross1);

                sf::RectangleShape cross2(sf::Vector2f(200.f, 10.f));
                cross2.setFillColor(sf::Color::Red);
                cross2.setPosition(xOffset + 160.f, yOffset + 20.f);
                cross2.setRotation(135.f);
                window.draw(cross2);
            }
        }
    }
}
